# Copy to .env for local overrides. All variables are prefixed with APP_.

# Database (SQLite for local dev; use a Postgres URL in production)
# APP_DATABASE_URL=sqlite:///./app.db
# APP_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# Voter identity comes from a client-supplied X-Visitor-Id header (a FingerprintJS
# browser fingerprint), so there is no server-side secret to configure.

# Location of the built frontend bundle served in production.
# APP_FRONTEND_DIR=frontend/dist
